{
  "expo": {
    "name": "Book a Train — Athlete",
    "slug": "bat-athlete",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bookatrain.athlete",
      "infoPlist": {
        "UIBackgroundModes": ["location"]
      }
    },
    "android": {
      "package": "com.bookatrain.athlete",
      "adaptiveIcon": {
        "backgroundColor": "#070C18"
      }
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Book a Train to track your location during workouts to calculate distance and pace.",
          "locationWhenInUsePermission": "Allow Book a Train to track your location during workouts to calculate distance and pace.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],
    "scheme": "bat-athlete",
    "experiments": {
      "typedRoutes": true
    }
  }
}
